{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "프랜차이즈 매장 데이터",
  "description": "프랜차이즈 매장 수집 결과 표준 스키마",
  "type": "object",
  "required": ["meta", "stores"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["brand_id", "brand_name", "totalCount", "extractedAt", "sourceUrl"],
      "additionalProperties": false,
      "properties": {
        "brand_id": {
          "type": "string",
          "description": "브랜드 고유 ID (영문 키, 사용자 입력)"
        },
        "brand_name": {
          "type": "string",
          "description": "브랜드명 (한글, 사용자 입력)"
        },
        "totalCount": {
          "type": "integer",
          "minimum": 0,
          "description": "매장 수"
        },
        "extractedAt": {
          "type": "string",
          "format": "date-time",
          "description": "추출 시각 (ISO 8601)"
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri",
          "description": "수집 원본 URL"
        }
      }
    },
    "stores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "address", "lat", "lng", "region", "district"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "순번 (1부터 시작)"
          },
          "name": {
            "type": "string",
            "description": "매장명 (브랜드명으로 시작하지 않으면 브랜드명을 접두어로 추가)"
          },
          "address": {
            "type": "string",
            "description": "도로명/지번 주소"
          },
          "contact": {
            "type": ["string", "null"],
            "description": "전화번호 (nullable)"
          },
          "lat": {
            "type": "string",
            "pattern": "^[0-9]{2}\\.[0-9]+$",
            "description": "위도 (WGS84, 문자열 — 정확도 보존)"
          },
          "lng": {
            "type": "string",
            "pattern": "^[0-9]{3}\\.[0-9]+$",
            "description": "경도 (WGS84, 문자열 — 정확도 보존)"
          },
          "region": {
            "type": "string",
            "description": "시/도 (주소 첫 번째 토큰)"
          },
          "district": {
            "type": "string",
            "description": "시/군/구 (주소 두 번째 토큰)"
          }
        }
      }
    }
  }
}
