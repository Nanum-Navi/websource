# websource environment variables
# Copy this file to .env and customize as needed.
# All variables are optional — defaults are shown in comments.

# Override the data directory (default: ~/.local/share/websource)
# WEBSOURCE_DATA_DIR=/path/to/data

# Override the config directory (default: ~/.config/websource)
# WEBSOURCE_CONFIG_DIR=/path/to/config

# Log level: trace | debug | info | warn | error (default: warn)
# LOG_LEVEL=warn

# Set to "production" to write logs to a file instead of stderr
# NODE_ENV=production

# Naver Cloud Platform — Geocoding API
# Required for scripts/geocode-stores.ts and src/geocoding module
# NCP_CLIENT_ID=your_client_id
# NCP_CLIENT_SECRET=your_client_secret
