{
  "input": {
    "required": ["brand_id", "brand_name", "url"],
    "description": "사용자가 제공하는 3가지 입력값"
  },
  "naming": {
    "fileNamePattern": "{brand_name}({brand_id}).json",
    "outputDirectory": "data/"
  },
  "fields": {
    "required": ["name", "address", "lat", "lng"],
    "optional": ["contact"],
    "fieldMapping": {
      "name": {
        "aliases": ["매장명", "점포명", "가맹점명", "store_name", "shopName", "branch_name"],
        "type": "string"
      },
      "address": {
        "aliases": ["주소", "도로명주소", "addr", "address", "road_address", "roadAddr"],
        "type": "string"
      },
      "contact": {
        "aliases": ["전화번호", "연락처", "tel", "phone", "telephone"],
        "type": "string",
        "nullable": true
      },
      "lat": {
        "aliases": ["위도", "latitude", "y", "lat", "ycoord"],
        "type": "string"
      },
      "lng": {
        "aliases": ["경도", "longitude", "x", "lng", "xcoord"],
        "type": "string"
      }
    }
  },
  "transforms": {
    "name": {
      "prefixWithBrandName": true,
      "description": "매장명이 brand_name으로 시작하지 않으면 '{brand_name} {name}' 형태로 변환"
    },
    "lat": {
      "keepAsString": true,
      "description": "정확도 보존을 위해 문자열 유지"
    },
    "lng": {
      "keepAsString": true,
      "description": "정확도 보존을 위해 문자열 유지"
    },
    "region": {
      "deriveFromAddress": true,
      "description": "normalizeStoreAddress()로 정규화된 현행 17개 공식 시/도명"
    },
    "district": {
      "deriveFromAddress": true,
      "description": "normalizeStoreAddress()로 추출된 시/군/구 (주소 두 번째 토큰)"
    }
  },
  "deduplication": {
    "keys": ["name", "address"]
  },
  "extraction": {
    "defaultFetchMode": "rendered",
    "rateLimitMs": 1000,
    "maxPages": 500,
    "robotsPolicy": "respect"
  },
  "validation": {
    "coordinateRange": {
      "lat": { "min": 33, "max": 39 },
      "lng": { "min": 124, "max": 132 }
    },
    "errorThreshold": 0.05,
    "errorThresholdDescription": "전체 레코드 중 5% 이상 오류 시 추출 실패 처리"
  }
}
